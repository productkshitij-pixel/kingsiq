# ── Supabase (same values as your current .env) ───────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Supabase service role key (for User Management — admin only) ─
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Backend (set this to your Railway URL after deploying) ─
VITE_BACKEND_URL=https://kingsiq-backend.up.railway.app
